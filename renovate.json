{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on Friday"],
  "timezone": "Asia/Tokyo",
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "non-major dependencies",
      "groupSlug": "non-major"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "client-react 1.5.0 has broken packaging (dist/index.d.ts uses unscoped imports), causing PipecatClient type re-declaration in next build. Re-evaluate when upstream ships a fix.",
      "matchPackageNames": ["@pipecat-ai/client-react"],
      "allowedVersions": "<1.5.0"
    },
    {
      "description": "eslint 10 is incompatible with eslint-plugin-react bundled by eslint-config-next 16 (contextOrFilename.getFilename is not a function). Re-evaluate when eslint-config-next updates the plugin.",
      "matchPackageNames": ["eslint"],
      "allowedVersions": "<10"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on Friday"]
  }
}
